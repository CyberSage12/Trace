---
import UserConfig from '../components/UserConfig';
import '../styles/global.css'; 
import Navbar from '../components/Navbar.astro';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>Planificador de Ruta | TraceRoute</title>
  </head>
  <body>
    <Navbar />
    <main style="max-width: 1000px; margin: 40px auto; padding: 20px;">
      
      <div style="text-align: center; margin-bottom: 30px;">
        <h1 style="color: #2ea043; font-size: 2.5rem; margin-bottom: 10px;">Planificador de Trayectoria</h1>
        <p style="color: #8b949e; font-size: 1.1rem;">
          Selecciona las materias que ya cursaste y definamos tu ruta óptima de egreso.
        </p>
      </div>

      <!-- Aquí es donde ocurre la magia de la malla interactiva -->
      <UserConfig client:load />

    </main>
  </body>
</html>