---
// Un componente de Astro puro, sin React.
import logoTraceRoute from '../assets/favicon.png';
---

<nav style="background-color: #161b22; padding: 15px 40px; border-bottom: 1px solid #30363d; display: flex; justify-content: space-between; align-items: center;">
  
  
  <a href="/" style="display: flex; align-items: center; gap: 10px; color: #58a6ff; font-size: 1.5rem; font-weight: 900; text-decoration: none;">
  <img src={logoTraceRoute.src} alt="TraceRoute Logo" style="width: 35px; height: 35px;" />
  Trace
  </a>

  {/* Los enlaces de navegación */}
  <div style="display: flex; gap: 20px; align-items: center;">
    <a href="/materias" style="color: #c9d1d9; text-decoration: none; font-weight: 500; font-size: 1rem;">
      Explorar Malla
    </a>
    <a href="/test" style="background-color: #238636; color: white; text-decoration: none; font-weight: bold; padding: 8px 16px; border-radius: 6px; font-size: 0.95rem;">
      Hacer el Test
    </a>
    <a href="/planificador" class="nav-btn-traceroute">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px;"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
    TraceRoute
    </a>
  </div>
</nav>

<style>
  nav a {
    transition: all 0.2s ease-in-out;
  }
  nav a:hover {
    filter: brightness(1.2);
  }
  .nav-btn-traceroute {
    display: inline-flex;
    align-items: center;
    background-color: transparent;
    color: #58a6ff;
    border: 1px solid rgba(88, 166, 255, 0.4);
    padding: 6px 12px;
    border-radius: 6px;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.2s ease;
  }

  .nav-btn-traceroute:hover {
    background-color: rgba(88, 166, 255, 0.1);
    border-color: #58a6ff;
    box-shadow: 0 0 8px rgba(88, 166, 255, 0.3);
  }
</style>